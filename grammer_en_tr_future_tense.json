{
  "level": 10,
  "topic": "Türkçe Gelecek Zaman (-ecek / -acak)",
  "language_pair": "en-tr",
  "target_language": "tr",
  "native_language": "en",
  "description": "Turkish Future Tense (-ecek/-acak) – for English speakers. Used for future actions, plans, predictions, and intentions. Similar to English 'will' + verb or 'be going to' + verb, but Turkish has one main structure for most future meanings: 'I will go' / 'I'm going to go' → 'Gideceğim'.",
  "grammar_focus": {
    "rule": "Verb stem + -ecek / -acak (vowel harmony) + personal ending",
    "suffixes": {
      "ben (I)": "-eceğim / -acağım",
      "sen (you)": "-eceksin / -acaksın",
      "o (he/she/it)": "-ecek / -acak",
      "biz (we)": "-eceğiz / -acağız",
      "siz (you plural)": "-eceksiniz / -acaksınız",
      "onlar (they)": "-ecekler / -acaklar"
    },
    "note_en": "The future suffix follows vowel harmony: last vowel is back → -acak, front → -ecek. Negation: add -me/-ma before the future suffix: gitmeyeceğim, gelmeyecek. Questions: add mi/mı/mu/mü after the personal ending: Gidecek misin? No separate 'will' or 'going to' distinction like in English – one form covers most future situations (plans, predictions, spontaneous decisions)."
  },
