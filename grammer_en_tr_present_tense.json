  "topic": "Türkçe Geniş Zaman (Simple Present equivalent)",
  "language_pair": "en-tr",
  "target_language": "tr",
  "native_language": "en",
  "description": "Turkish Geniş Zaman (habitual/general present) – for English speakers. Used for habits, general truths, repeated actions, feelings, states, and schedules. Very similar to English Present Simple: 'I go every day' → 'Her gün giderim'.",
  "grammar_focus": {
    "rule": "Verb stem + geniş zaman suffix (-r / -ar / -er / -ır / -ir / -ur / -ür) + personal ending",
    "suffixes": {
      "ben (I)": "-ım / -im / -um / -üm / -am / -em (vowel harmony)",
      "sen (you)": "-sın / -sin / -sun / -sün",
      "o (he/she/it)": "no personal ending, just the tense suffix (-ar/-er/-ır/-ir/-ur/-ür)",
      "biz (we)": "-ız / -iz / -uz / -üz",
      "siz (you plural)": "-sınız / -siniz / -sunuz / -sünüz",
      "onlar (they)": "-lar / -ler (added after the tense suffix)"
    },
    "note_en": "Turkish geniş zaman works almost exactly like English Present Simple. Pay attention to vowel harmony: back vowels → -ar/-ır/-ur, front vowels → -er/-ir/-ür. Some verbs are irregular (gel → gelir, ver → verir, bil → bilir). Negation: use -maz/-mez instead of the positive suffix: gitmez, gelmez. Questions: add mi/mı/mu/mü after the personal ending: Gider misin?"
  },
