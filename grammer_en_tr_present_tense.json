    { "pronoun": "O", "en": "He/She/It", "suffix": "no personal ending" },
    { "pronoun": "Biz", "en": "We", "suffix": "-ız / -iz / -uz / -üz" },
    { "pronoun": "Siz", "en": "You (plural)", "suffix": "-sınız / -siniz / -sunuz / -sünüz" },
