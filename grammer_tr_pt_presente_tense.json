  "vowel_harmony_guide": {
    "title": "Guia de Harmonia Vocálica para -iyor",
    "pt_explanation": "A última vogal da raiz do verbo determina qual forma de -iyor usar:",
    "rules": [
      { "last_vowel": "e, i", "suffix": "-iyor", "example": "gel → geliyor" },
      { "last_vowel": "a, ı", "suffix": "-ıyor", "example": "yap → yapıyor" },
      { "last_vowel": "o, u", "suffix": "-uyor", "example": "koş → koşuyor" },
      { "last_vowel": "ö, ü", "suffix": "-üyor", "example": "gör → görüyor" }
    ]
  },
