  "topic": "Portuguese Past Tenses (Pretérito Perfeito & Pretérito Imperfeito)",
  "language_pair": "en-pt",
  "target_language": "pt",
  "native_language": "en",
  "description": "Portuguese Past Tenses – for English speakers. Portuguese has two main simple past tenses: 1. Pretérito Perfeito (Preterite/Simple Past) for completed, specific actions in the past (like English simple past: 'I ate'). 2. Pretérito Imperfeito (Imperfect) for ongoing, habitual, repeated, or descriptive past actions (like 'I used to eat' or 'I was eating'). Understanding the difference is key – similar to Spanish preterite vs. imperfect.",
  "grammar_focus": {
    "rule_perfeito": "Verb stem + endings (regular -ar: -ei, -aste/-aste, -ou/-ou, -amos, -aram; -er: -i, -este, -eu, -emos, -eram; -ir: -i, -iste, -iu, -imos, -iram)",
    "rule_imperfeito": "Verb stem + endings (regular -ar: -ava, -avas, -ava, -ávamos, -avam; -er/-ir: -ia, -ias, -ia, -íamos, -iam)",
    "suffixes_perfeito": {
      "eu (I)": "-ei / -i",
      "tu (you informal)": "-aste / -este / -iste",
      "você/ele/ela (you formal/he/she/it)": "-ou / -eu / -iu",
      "nós (we)": "-amos / -emos / -imos",
      "vocês/eles/elas (you plural/they)": "-aram / -eram / -iram"
    },
    "suffixes_imperfeito": {
      "eu (I)": "-ava / -ia",
      "tu (you informal)": "-avas / -ias",
      "você/ele/ela (you formal/he/she/it)": "-ava / -ia",
      "nós (we)": "-ávamos / -íamos",
      "vocês/eles/elas (you plural/they)": "-avam / -iam"
    },
    "note_en": "Pretérito Perfeito = completed actions with definite beginning/end (yesterday, last week, once). Pretérito Imperfeito = background, descriptions, habits in the past, ongoing situations, 'used to'. Many common verbs are irregular in Perfeito (ser/ir/ter/vir/fazer/dizer/poder/querer/saber/estar etc.). Negation: não + verb. Questions: intonation or subject-verb inversion."
  },
